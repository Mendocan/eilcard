# Üretim ortam değişkenleri — bu dosyayı .env.prod olarak kopyalayıp doldurun
# VPS'te: cp .env.prod.example .env.prod && nano .env.prod

# Güçlü bir Postgres şifresi (örn: openssl rand -base64 24)
POSTGRES_PASSWORD=change-me-strong-password

# Better Auth secret (örn: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-min-32-chars-random

# Domain (Caddy otomatik SSL için — sadece host, https/şema yok)
APP_DOMAIN=eilcard.com

# Uygulamanın canlı adresi (https dahil)
APP_URL=https://eilcard.com

# Resend e-posta API anahtarı (uygulama işlem mailleri için)
RESEND_API_KEY=re_xxx

# Resmi iletişim adresleri (posta kutusu kurulduktan sonra)
SUPPORT_EMAIL=support@eilcard.com
BILLING_EMAIL=billing@eilcard.com

# Dashboard user for EIL Card itself (not customer pilots) — register then run ensure-platform-operator.mjs
PLATFORM_OPERATOR_EMAIL=platform@eilcard.com

# Admin panel şifresi (/admin) — min 8 karakter, güçlü seçin
ADMIN_PASSWORD=change-me-strong-admin-password

# GitHub repo (landing ikonu)
NEXT_PUBLIC_GITHUB_URL=https://github.com/Mendocan/eilcard

{
  "name": "@digitalcard/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for EIL Card — resolve canonical entity profiles for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "export:tools": "node scripts/export-tool-definitions.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "eil",
    "digital-card",
    "entity-identity",
    "agent",
    "schema.org",
    "llms",
    "resolve"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mendocan/eilcard.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://eilcard.com",
  "bugs": {
    "url": "https://github.com/Mendocan/eilcard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}

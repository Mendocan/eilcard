# Database
DATABASE_URL=postgresql://digitalcard:localdev@localhost:5432/digitalcard

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000

# Resend (transactional email from the app)
RESEND_API_KEY=re_xxx

# Official contact addresses (shown on site after mailbox setup)
SUPPORT_EMAIL=support@eilcard.com
BILLING_EMAIL=billing@eilcard.com

# Registry operator dashboard account (separate from customers)
PLATFORM_OPERATOR_EMAIL=platform@eilcard.com

# Admin console (optional in dev)
ADMIN_PASSWORD=change-me-min-8-chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
